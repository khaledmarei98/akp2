rules_version = '2';

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// AKP Consulting Platform — Firestore Security Rules
//
// Deploy via:
//   firebase deploy --only firestore:rules
//
// Or in Firebase Console:
//   Firestore > Rules > paste this content > Publish
//
// Role hierarchy (stored in users/{uid}.role):
//   super_admin > admin_staff > instructor > accounting_partner > client > student
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fetches role from Firestore — used for admin checks.
    // NOTE: Each call costs one Firestore read; functions are cached within a
    // single request so a rule matching multiple paths won't re-fetch.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() in ['super_admin', 'admin_staff'];
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'super_admin';
    }

    function isInstructor() {
      return isSignedIn() && userRole() in ['super_admin', 'admin_staff', 'instructor'];
    }

    // Checks that incoming data only changed the listed keys (plus updatedAt
    // which our helpers always stamp). Useful for restricting partial updates.
    function onlyChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(keys.concat(['updatedAt']));
    }

    // ─── users ─────────────────────────────────────────────────────────────────
    // Users can read and update their own profile.
    // Only admins may change the 'role' field or read other users' profiles.
    // Only super_admin may delete user records.

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
                    && request.resource.data.role in ['client', 'student']
                    && request.resource.data.keys().hasAll(['name', 'email', 'role', 'isVerified']);

      allow update: if
        // Owner may update their own profile but cannot change their role
        (isOwner(userId)
          && !request.resource.data.diff(resource.data)
                .affectedKeys().hasAny(['role']))
        // Admins may update anything, including role assignment
        || isAdmin();

      allow delete: if isSuperAdmin();
    }

    // ─── resources (Library) ───────────────────────────────────────────────────
    // Resources are publicly readable.
    // Only admins may create, update, or delete resources.
    // Exception: any visitor may increment the downloads counter by exactly +1.
    // The updateDocument helper always stamps updatedAt, so we allow that too.

    match /resources/{resourceId} {
      allow read: if true;

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (
          // Download counter increment — open to all, authenticated or not
          onlyChanged(['downloads'])
          && request.resource.data.downloads == resource.data.downloads + 1
          && request.resource.data.downloads is int
        );

      allow delete: if isAdmin();
    }

    // ─── courses ───────────────────────────────────────────────────────────────
    // Public catalog. Only instructors (and above) may manage course content.

    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if isInstructor();
      allow delete: if isAdmin();
    }

    // ─── enrollments ───────────────────────────────────────────────────────────
    // Users may read and create their own enrollments.
    // Progress updates are also user-owned. Admins have full access.

    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ─── bookings ──────────────────────────────────────────────────────────────
    // Users may create and read their own bookings.
    // Only admins may update status or delete bookings.

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if request.resource.data.keys().hasAll([
                      'userId',
                      'customerName',
                      'email',
                      'serviceCategory',
                      'requestType',
                      'requestDetails',
                      'contactPreference',
                      'status'
                    ])
                    && request.resource.data.status == 'new'
                    && request.resource.data.serviceCategory in ['accounting', 'tax', 'hr', 'erp', 'financial', 'business', 'audit']
                    && (
                      (isSignedIn() && request.resource.data.userId == request.auth.uid)
                      || (!isSignedIn() && request.resource.data.userId == '')
                    );

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── contactMessages ──────────────────────────────────────────────────────
    // Public visitors can submit contact/chat messages. Admins manage them.

    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'source', 'status'])
                    && request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // ─── supportTickets ────────────────────────────────────────────────────────
    // Users may create tickets and update their own open tickets (add messages).
    // Admins may update any ticket (change status, add admin responses).

    match /supportTickets/{ticketId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'subject']);

      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.userId == request.auth.uid
                        // Users may only append messages, not change status/priority
                        && onlyChanged(['messages', 'lastMessageAt']));

      allow delete: if isAdmin();
    }

    // ─── subscriptions ─────────────────────────────────────────────────────────
    // Subscription records are managed exclusively by admins (e.g. after payment).
    // Users may only read their own subscription.

    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── notifications ─────────────────────────────────────────────────────────
    // Only admins create notifications. Users may read and dismiss their own.

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create, update: if isAdmin();

      // Users may mark their own notifications as dismissed/read
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // ─── clientDocuments ───────────────────────────────────────────────────────
    // Users can upload and read their own documents.
    // Admins can read, update status, and delete any document.

    match /clientDocuments/{documentId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'name', 'storagePath']);

      allow update: if isAdmin()
                    // Users may only update their own document metadata (not status)
                    || (isSignedIn()
                        && resource.data.userId == request.auth.uid
                        && onlyChanged(['name', 'description']));

      allow delete: if isAdmin();
    }

    // ─── articles ──────────────────────────────────────────────────────────────
    // Published articles are public. Only admins may create/edit/delete.

    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── payments / leads / teamMembers ───────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /teamMembers/{memberId} {
      allow read, create, update, delete: if isAdmin();
    }

  }
}
